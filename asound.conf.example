# ALSA Configuration to suppress errors and prevent segfaults
# Copy this to ~/.asoundrc or /etc/asound.conf
#
# This configuration:
# 1. Disables Jack audio plugin (prevents "jack server is not running" errors)
# 2. Simplifies PCM device access
# 3. Prevents PyAudio from probing non-existent virtual devices

# Disable Jack plugin to prevent segfaults
pcm.!default {
    type hw
    card 2  # Change this to your USB audio card number (from 'arecord -l')
    device 0
}

ctl.!default {
    type hw
    card 2  # Change this to match your card number
}

# Alternative: Use PulseAudio if available
# pcm.!default {
#     type pulse
# }
# ctl.!default {
#     type pulse
# }
